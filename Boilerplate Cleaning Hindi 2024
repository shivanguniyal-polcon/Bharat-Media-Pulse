    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.metrics import accuracy_score, cohen_kappa_score\n",
    "from statsmodels.stats.contingency_tables import mcnemar\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# ==========================================\n",
    "# 1. FILE PATHS CONFIGURATION\n",
    "# ==========================================\n",
    "# English Files (Blinded Audit + Key)\n",
    "ENG_AUDIT_FILE = '/kaggle/input/datasets/shivanguniyal/prong3/prong3_blinded_audit.csv' \n",
    "ENG_KEY_FILE = '/kaggle/input/datasets/shivanguniyal/prong3/prong3_audit_key.csv'\n",
    "\n",
    "# Hindi File (Single unblinded coded file)\n",
    "HINDI_CODED_FILE = '/kaggle/input/datasets/shivanguniyal/hindi-cascade-disagreements-2024/Hindi_Cascade_Disagreements_Export.csv' # 👈 Update with your actual Hindi filename\n",
    "\n",
    "results_summary = {}\n",
    "\n",
    "# ==========================================\n",
    "# 2. ENGLISH DATA: MERGE & UNBLIND\n",
    "# ==========================================\n",
    "print(\"=\"*70)\n",
    "print(\"🔍 PROCESSING: ENGLISH DATASET (Blinded Audit + Key)\")\n",
    "print(\"=\"*70)\n",
    "\n",
    "try:\n",
    "    eng_audit = pd.read_csv(ENG_AUDIT_FILE)\n",
    "    eng_key = pd.read_csv(ENG_KEY_FILE)\n",
    "    \n",
    "    # Create a safe merge key\n",
    "    for df in [eng_audit, eng_key]:\n",
    "        for col in ['date', 'newspaper', 'clean_text']:\n",
    "            if col not in df.columns: df[col] = \"\"\n",
    "            df[col] = df[col].astype(str).fillna(\"\")\n",
    "            \n",
    "    eng_key['merge_key'] = eng_key['date'] + \"_\" + eng_key['newspaper'] + \"_\" + eng_key['clean_text'].str[:50]\n",
    "    eng_audit['merge_key'] = eng_audit['date'] + \"_\" + eng_audit['newspaper'] + \"_\" + eng_audit['clean_text'].str[:50]\n",
    "\n",
    "    # Merge\n",
    "    eng_df = pd.merge(eng_audit, eng_key[['merge_key', 'label_trunc', 'label_hier']], on='merge_key', how='inner')\n",
    "    print(f\"✅ Successfully merged {len(eng_df)} English articles.\")\n",
    "\n",
    "    # Auto-Unblind\n",
    "    for col in ['Method_A', 'Method_B', 'label_trunc', 'label_hier', 'Human_Label']:\n",
    "        if col in eng_df.columns:\n",
    "            eng_df[col] = eng_df[col].astype(str).str.lower().str.strip()\n",
    "            \n",
    "    match_A_trunc = (eng_df['Method_A'] == eng_df['label_trunc']).mean()\n",
    "    match_B_trunc = (eng_df['Method_B'] == eng_df['label_trunc']).mean()\n",
    "    \n",
    "    if match_A_trunc > match_B_trunc:\n",
    "        eng_df['Truncated'] = eng_df['Method_A']\n",
    "        eng_df['Hierarchical'] = eng_df['Method_B']\n",
    "        print(\"🔓 Unblinded: Method A = Truncated | Method B = Hierarchical\")\n",
    "    else:\n",
    "        eng_df['Truncated'] = eng_df['Method_B']\n",
    "        eng_df['Hierarchical'] = eng_df['Method_A']\n",
    "        print(\"🔓 Unblinded: Method A = Hierarchical | Method B = Truncated\")\n",
    "\n",
    "    # Filter valid labels\n",
    "    valid_labels = ['critical', 'neutral', 'supportive']\n",
    "    eng_df = eng_df[\n",
    "        eng_df['Human_Label'].isin(valid_labels) & \n",
    "        eng_df['Truncated'].isin(valid_labels) & \n",
    "        eng_df['Hierarchical'].isin(valid_labels)\n",
    "    ].copy()\n",
    "    \n",
    "    results_summary['English'] = eng_df\n",
    "\n",
    "except Exception as e:\n",
    "    print(f\"⚠️ Error processing English data: {e}\")\n",
    "\n",
    "# ==========================================\n",
    "# 3. HINDI DATA: SINGLE UNBLINDED FILE\n",
    "# ==========================================\n",
    "print(\"\\n\" + \"=\"*70)\n",
    "print(\"🔍 PROCESSING: HINDI DATASET (Single Unblinded File)\")\n",
    "print(\"=\"*70)\n",
    "\n",
    "try:\n",
    "    hin_df = pd.read_csv(HINDI_CODED_FILE)\n",
    "    print(f\"✅ Successfully loaded {len(hin_df)} Hindi articles.\")\n",
    "    \n",
    "    # Standardize column names (flexible mapping)\n",
    "    col_map = {}\n",
    "    for col in hin_df.columns:\n",
    "        lower_col = col.lower().strip()\n",
    "        if lower_col in ['trunc_label', 'truncated', 'method_trunc']:\n",
    "            col_map[col] = 'Truncated'\n",
    "        elif lower_col in ['hier_label', 'hierarchical', 'method_hier']:\n",
    "            col_map[col] = 'Hierarchical'\n",
    "        elif lower_col in ['human_label', 'human', 'coder_label']:\n",
    "            col_map[col] = 'Human_Label'\n",
    "            \n",
    "    hin_df.rename(columns=col_map, inplace=True)\n",
    "    \n",
    "    # Standardize label text\n",
    "    for col in ['Truncated', 'Hierarchical', 'Human_Label']:\n",
    "        if col in hin_df.columns:\n",
    "            hin_df[col] = hin_df[col].astype(str).str.lower().str.strip()\n",
    "            \n",
    "    # Filter valid labels\n",
    "    valid_labels = ['critical', 'neutral', 'supportive']\n",
    "    hin_df = hin_df[\n",
    "        hin_df['Human_Label'].isin(valid_labels) & \n",
    "        hin_df['Truncated'].isin(valid_labels) & \n",
    "        hin_df['Hierarchical'].isin(valid_labels)\n",
    "    ].copy()\n",
    "    \n",
    "    results_summary['Hindi'] = hin_df\n",
    "\n",
    "except Exception as e:\n",
    "    print(f\"⚠️ Error processing Hindi data: {e}\")\n",
    "\n",
    "# ==========================================\n",
    "# 4. METRICS CALCULATION FUNCTION\n",
    "# ==========================================\n",
    "def calculate_metrics(df, lang_name):\n",
    "    if df.empty:\n",
    "        print(f\"⚠️ No valid data for {lang_name}.\")\n",
    "        return None\n",
    "        \n",
    "    print(f\"\\n📊 METRICS FOR: {lang_name.upper()} (N = {len(df)})\")\n",
    "    print(\"-\"*70)\n",
    "    \n",
    "    # Accuracies & Kappa\n",
    "    acc_trunc = accuracy_score(df['Human_Label'], df['Truncated'])\n",
    "    acc_hier = accuracy_score(df['Human_Label'], df['Hierarchical'])\n",
    "    kappa_trunc = cohen_kappa_score(df['Human_Label'], df['Truncated'])\n",
    "    kappa_hier = cohen_kappa_score(df['Human_Label'], df['Hierarchical'])\n",
    "    \n",
    "    print(f\"Truncated Accuracy:    {acc_trunc:.1%}  (Cohen's κ: {kappa_trunc:.3f})\")\n",
    "    print(f\"Hierarchical Accuracy: {acc_hier:.1%}  (Cohen's κ: {kappa_hier:.3f})\")\n",
    "    print(f\"Absolute Improvement:  +{(acc_hier - acc_trunc)*100:.1f} percentage points\")\n",
    "\n",
    "    # McNemar's Test\n",
    "    trunc_right_hier_wrong = ((df['Truncated'] == df['Human_Label']) & (df['Hierarchical'] != df['Human_Label'])).sum()\n",
    "    trunc_wrong_hier_right = ((df['Truncated'] != df['Human_Label']) & (df['Hierarchical'] == df['Human_Label'])).sum()\n",
    "\n",
    "    if trunc_right_hier_wrong == 0 and trunc_wrong_hier_right == 0:\n",
    "        p_value = 1.0\n",
    "    else:\n",
    "        table = np.array([[0, trunc_right_hier_wrong],\n",
    "                          [trunc_wrong_hier_right, 0]])\n",
    "        result = mcnemar(table, exact=True)\n",
    "        p_value = result.pvalue\n",
    "\n",
    "    print(f\"\\nMcNemar's Test (Is Hierarchical statistically superior?):\")\n",
    "    print(f\"Trunc RIGHT / Hier WRONG: {trunc_right_hier_wrong}\")\n",
    "    print(f\"Trunc WRONG / Hier RIGHT: {trunc_wrong_hier_right}\")\n",
    "    print(f\"p-value: {p_value:.4f} {'✅ SIGNIFICANT' if p_value < 0.05 else '⚠️ NOT SIGNIFICANT'}\")\n",
    "\n",
    "    # Head-to-Head on Disagreements\n",
    "    df_disagree = df[df['Truncated'] != df['Hierarchical']]\n",
    "    hier_wins, trunc_wins = 0, 0\n",
    "    if len(df_disagree) > 0:\n",
    "        hier_wins = ((df_disagree['Hierarchical'] == df_disagree['Human_Label']) & (df_disagree['Truncated'] != df_disagree['Human_Label'])).sum()\n",
    "        trunc_wins = ((df_disagree['Truncated'] == df_disagree['Human_Label']) & (df_disagree['Hierarchical'] != df_disagree['Human_Label'])).sum()\n",
    "        both_wrong = ((df_disagree['Truncated'] != df_disagree['Human_Label']) & (df_disagree['Hierarchical'] != df_disagree['Human_Label'])).sum()\n",
    "        \n",
    "        print(f\"\\nHead-to-Head on Disagreements (N={len(df_disagree)}):\")\n",
    "        print(f\"✅ Hierarchical was RIGHT, Truncated was WRONG: {hier_wins} times\")\n",
    "        print(f\"❌ Truncated was RIGHT, Hierarchical was WRONG: {trunc_wins} times\")\n",
    "        print(f\"⚠️  Both models were WRONG:                    {both_wrong} times\")\n",
    "        \n",
    "    return {\n",
    "        'N': len(df),\n",
    "        'Trunc_Acc': acc_trunc,\n",
    "        'Hier_Acc': acc_hier,\n",
    "        'Kappa_Trunc': kappa_trunc,\n",
    "        'Kappa_Hier': kappa_hier,\n",
    "        'McNemar_p': p_value,\n",
    "        'Hier_Wins': hier_wins,\n",
    "        'Trunc_Wins': trunc_wins\n",
    "    }\n",
    "\n",
    "# ==========================================\n",
    "# 5. RUN METRICS & COMPARATIVE SUMMARY\n",
    "# ==========================================\n",
    "eng_metrics = calculate_metrics(results_summary.get('English', pd.DataFrame()), 'English')\n",
    "hin_metrics = calculate_metrics(results_summary.get('Hindi', pd.DataFrame()), 'Hindi')\n",
    "\n",
    "print(\"\\n\" + \"=\"*70)\n",
    "print(\"🏆 CROSS-LINGUAL COMPARATIVE SUMMARY\")\n",
    "print(\"=\"*70)\n",
    "\n",
    "if eng_metrics and hin_metrics:\n",
    "    print(f\"{'Metric':<35} | {'English':<15} | {'Hindi':<15}\")\n",
    "    print(\"-\"*70)\n",
    "    \n",
    "    rows = [\n",
    "        (\"Total Articles Coded\", f\"{eng_metrics['N']}\", f\"{hin_metrics['N']}\"),\n",
    "        (\"Truncated Accuracy\", f\"{eng_metrics['Trunc_Acc']:.1%}\", f\"{hin_metrics['Trunc_Acc']:.1%}\"),\n",
    "        (\"Hierarchical Accuracy\", f\"{eng_metrics['Hier_Acc']:.1%}\", f\"{hin_metrics['Hier_Acc']:.1%}\"),\n",
    "        (\"Absolute Improvement\", f\"+{(eng_metrics['Hier_Acc'] - eng_metrics['Trunc_Acc'])*100:.1f} pp\", f\"+{(hin_metrics['Hier_Acc'] - hin_metrics['Trunc_Acc'])*100:.1f} pp\"),\n",
    "        (\"Cohen's κ (Truncated)\", f\"{eng_metrics['Kappa_Trunc']:.3f}\", f\"{hin_metrics['Kappa_Trunc']:.3f}\"),\n",
    "        (\"Cohen's κ (Hierarchical)\", f\"{eng_metrics['Kappa_Hier']:.3f}\", f\"{hin_metrics['Kappa_Hier']:.3f}\"),\n",
    "        (\"McNemar's p-value\", f\"{eng_metrics['McNemar_p']:.4f}\", f\"{hin_metrics['McNemar_p']:.4f}\"),\n",
    "        (\"Hierarchical Wins (Disagreements)\", f\"{eng_metrics['Hier_Wins']}\", f\"{hin_metrics['Hier_Wins']}\"),\n",
    "        (\"Truncated Wins (Disagreements)\", f\"{eng_metrics['Trunc_Wins']}\", f\"{hin_metrics['Trunc_Wins']}\")\n",
    "    ]\n",
    "    \n",
    "    for label, eng_val, hin_val in rows:\n",
    "        print(f\"{label:<35} | {eng_val:<15} | {hin_val:<15}\")\n",
    "        \n",
    "    print(\"\\n✅ Cross-Lingual Validation Complete.\")\n",
    "else:\n",
    "    print(\"⚠️ Could not generate comparative summary (missing data for one or both languages).\")"
