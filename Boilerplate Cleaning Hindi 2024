    "            break\n",
    "            \n",
    "print(f\"🧹 Cleaning text in column: '{TEXT_COLUMN}'...\")\n",
    "\n",
    "# Apply the cleaning function with a progress bar\n",
    "tqdm.pandas()\n",
    "df['final_clean_text'] = df[TEXT_COLUMN].progress_apply(clean_hindi_article)\n",
