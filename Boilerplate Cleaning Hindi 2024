    "    r\"कॉपी लिंक\"\n",
    "]\n",
    "\n",
    "# ==========================================\n",
    "# 5. THE MASTER CLEANING FUNCTION\n",
    "# ==========================================\n",
    "def clean_hindi_article(text):\n",
    "    if not isinstance(text, str):\n",
    "        return \"\"\n",
    "    \n",
    "    # Normalize whitespace initially\n",
    "    text = re.sub(r'\\s+', ' ', text).strip()\n",
    "    \n",
    "    # --- PASS A: JSON / METADATA HEADER REMOVAL ---\n",
    "    text = re.sub(r'^\\{.*?\\}\\s*', '', text, flags=re.DOTALL)\n",
    "    if text.startswith('{'): \n",
    "        text = re.sub(r'^\\{.*?\\}\\s*', '', text)\n",
    "\n",
    "    # --- PASS B: THE GUILLOTINE (Truncate footers) ---\n",
    "    for trigger in guillotine_triggers:\n",
    "        parts = re.split(trigger, text, maxsplit=1, flags=re.IGNORECASE)\n",
    "        if len(parts) > 1:\n",
    "            text = parts[0] # Keep only the text BEFORE the trigger\n",
    "            \n",
    "    # --- PASS C: EXACT PARAGRAPH REMOVAL ---\n",
    "    for para in boilerplate_paras:\n",
    "        if para in text:\n",
    "            text = text.replace(para, \"\")\n",
    "            \n",
    "    # --- PASS D: SMART N-GRAM REMOVAL (Inline ads) ---\n",
    "    for ng in cleaned_ngrams:\n",
    "        if ng in text:\n",
    "            text = text.replace(ng, \"\")\n",
    "            \n",
    "    # --- PASS E: REGEX ARTIFACT CLEANUP ---\n",
    "    text = re.sub(r'\\bविज्ञापन\\b', '', text)\n",
    "    text = re.sub(r'HighLights\\s*-', '', text)\n",
    "    text = re.sub(r'और पढ़ें\\s*$', '', text)\n",
    "    text = re.sub(r'ये भी पढ़ें\\s*$', '', text)\n",
    "    text = re.sub(r'विस्तार\\s*$', '', text)\n",
    "    \n",
    "    # --- PASS F: AUTHOR / EDITOR BIO & TIMESTAMP REMOVAL ---\n",
    "    # Removes \"Edited By [Name],Updated: [Date] [Time] AM/PM\" from the start of the text\n",
    "    text = re.sub(r'^Edited By .*?(?:AM|PM)\\s*', '', text, flags=re.IGNORECASE)\n",
    "    # Removes \"By [Name], Updated: ...\" or just \"Updated: ...\" from the start\n",
    "    text = re.sub(r'^(?:By .*?)?,?\\s*Updated: .*?(?:AM|PM)\\s*', '', text, flags=re.IGNORECASE)\n",
    "    # Catch-all for generic editor tags at the very beginning if they don't have AM/PM\n",
    "    text = re.sub(r'^Edited By [^,]*,\\s*', '', text, flags=re.IGNORECASE)\n",
    "    \n",
    "    # Final whitespace and punctuation cleanup\n",
    "    text = re.sub(r'\\s+', ' ', text).strip()\n",
    "    text = re.sub(r'[,\\s]*।[,\\s]*$', '।', text)\n",
    "    text = re.sub(r'[,\\s]*\\.[,\\s]*$', '.', text)\n",
    "    \n",
    "    return text\n",
    "\n",
