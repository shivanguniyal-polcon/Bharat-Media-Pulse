    "import pandas as pd\n",
    "import re\n",
    "import numpy as np\n",
    "from tqdm import tqdm\n",
    "\n",
    "# ==========================================\n",
    "# 1. CONFIGURATION & FILE PATHS\n",
    "# ==========================================\n",
    "# 👇 UPDATE THESE PATHS to your actual file locations\n",
    "INPUT_CORPUS_PATH = '/kaggle/input/notebooks/shivanguniyal/script-3-5-hindi-topic-labeling-3-tier-theory/FINAL_Hindi_Level1_CorePolitical_2024.csv' \n",
    "OUTPUT_CLEANED_PATH = '/kaggle/working/Hindi_Corpus_Cleaned.csv'\n",
    "\n",
    "# Paths to the discovered boilerplate CSVs\n",
    "PARAGRAPHS_CSV_PATH = '/kaggle/input/datasets/shivanguniyal/boilerplate-hindi-2024/all_boilerplate_paragraphs.csv'\n",
    "NGRAMS_CSV_PATH = '/kaggle/input/datasets/shivanguniyal/boilerplate-hindi-2024/all_boilerplate_ngrams.csv'\n",
    "\n",
    "# The text column name in your CSV (The script will auto-detect if this is slightly off)\n",
    "TEXT_COLUMN = 'clean_text' \n",
    "\n",
    "# ==========================================\n",
    "# 2. LOAD BOILERPLATE LISTS\n",
    "# ==========================================\n",
    "print(\"📂 Loading boilerplate lists...\")\n",
    "df_paras = pd.read_csv(PARAGRAPHS_CSV_PATH)\n",
    "df_ngrams = pd.read_csv(NGRAMS_CSV_PATH)\n",
    "\n",
    "boilerplate_paras = df_paras['Text'].dropna().tolist()\n",
    "boilerplate_ngrams = df_ngrams['Text'].dropna().tolist()\n",
    "\n",
    "# ==========================================\n",
    "# 3. CURATE N-GRAMS (PROTECT JOURNALISM)\n",
    "# ==========================================\n",
    "print(\"🛡️ Curating N-grams to protect actual journalism...\")\n",
    "news_keywords = [\n",
    "    'मोदी', 'शाह', 'राहुल', 'गांधी', 'योगी', 'नीतीश', 'तेजस्वी', 'लालू', 'ममता', 'केजरीवाल', \n",
    "    'चुनाव', 'लोकसभा', 'विधानसभा', 'भाजपा', 'कांग्रेस', 'आप', 'सपा', 'बसपा', 'तृणमूल',\n",
    "    'प्रधानमंत्री', 'मुख्यमंत्री', 'मंत्री', 'सरकार', 'पुलिस', 'कोर्ट', 'न्यायालय', 'बैंक',\n",
    "    'करोड़', 'लाख', 'हजार', 'साल', 'महीने', 'दिन', 'भारत', 'देश', 'राज्य', 'शहर',\n",
    "    'कहा कि', 'बोले', 'घोषणा', 'आरोप', 'गिरफ्तार', 'नोटिस', 'ED', 'CBI'\n",
    "]\n",
    "\n",
    "cleaned_ngrams = []\n",
    "for ng in boilerplate_ngrams:\n",
    "    # Keep the n-gram ONLY IF it does not contain core news keywords\n",
    "    if not any(keyword in ng for keyword in news_keywords):\n",
    "        cleaned_ngrams.append(ng)\n",
    "\n",
    "print(f\"✓ Protected {len(boilerplate_ngrams) - len(cleaned_ngrams)} news-related n-grams.\")\n",
    "print(f\"✓ Using {len(cleaned_ngrams)} structural/ad n-grams for deletion.\")\n",
    "\n",
    "# ==========================================\n",
    "# 4. DEFINE \"GUILLOTINE\" TRIGGERS\n",
    "# ==========================================\n",
    "# Hardcoded regex triggers for safety to chop off footers\n",
    "guillotine_triggers = [\n",
    "    r\"कन्वर्सेशन शुरू करें\",\n",
    "    r\"इन सब की जानकारी, सबसे पहले\",\n",
